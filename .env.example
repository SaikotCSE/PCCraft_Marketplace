# ───────────────────────────────────────────────────────────────
# PCCraft Marketplace — environment variable template
# Copy to backend/.env (never commit the real .env file)
# ───────────────────────────────────────────────────────────────

# Django ─────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ENV=development          # development | production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL 18+) ─────────────────────────────────────
DB_NAME=pccraft
DB_USER=pccraft
DB_PASSWORD=pccraft
DB_HOST=127.0.0.1
DB_PORT=5432

# Redis 7+ ──────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# CORS ──────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email (SMTP — optional, only needed for vendor approval emails)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_FROM=no-reply@pccraft.local

# Frontend (Vite) ───────────────────────────────────────────────
# Place at frontend/.env
# VITE_API_BASE_URL=http://localhost:8000/api/v1